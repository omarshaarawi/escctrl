{
  "$schema": "https://raw.githubusercontent.com/nicklama/tauri-apps/tauri-v2/packages/api/schema.json",
  "productName": "escctrl",
  "version": "0.1.0",
  "identifier": "com.omarshaarawi.escctrl",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "createUpdaterArtifacts": false
  }
}
